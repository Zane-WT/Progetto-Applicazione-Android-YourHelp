<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CDEBFF">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- LOGO -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="138dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="16dp"
            android:src="@mipmap/ic_launcher_foreground" />

        <!-- TITOLO -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YourHelp"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#1A73E8"
            android:layout_marginBottom="30dp" />

        <!-- ACCEDI -->
        <TextView
            android:id="@+id/loginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accedi"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="20dp" />

        <!-- USERNAME / EMAIL -->
        <EditText
            android:id="@+id/textEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Username / Email"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:textColor="#000000"
            android:textColorHint="#777777"
            android:layout_marginBottom="16dp" />

        <!-- PASSWORD -->
        <EditText
            android:id="@+id/textPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Password"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textPassword"
            android:textColor="#000000"
            android:textColorHint="#777777"
            android:layout_marginBottom="24dp" />

        <!-- BOTTONE ENTRA -->
        <Button
            android:id="@+id/sendButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Entra"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#1A73E8"
            android:textColor="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginBottom="20dp" />

        <!-- LINK REGISTRAZIONE -->
        <TextView
            android:id="@+id/registerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Non hai un account? Registrati qui"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="40dp" />

        <!-- BOTTONE INVIA EMAIL VERIFICA (se vuoi tenerlo) -->
        <Button
            android:id="@+id/verifybutton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Invia Email di Verifica"
            android:textSize="16sp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#1A73E8"
            android:elevation="4dp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>

</ScrollView>