<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CDEBFF">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- LOGO -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="335dp"
            android:layout_height="239dp"
            android:src="@drawable/logoscritta" />

        <!-- TITOLO -->

        <!-- ACCEDI -->
        <TextView
            android:id="@+id/loginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accedi"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="-30dp"/>

        <!-- USERNAME / EMAIL -->
        <EditText
            android:id="@+id/textEmail"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:hint="Username / Email"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#000000"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rounded_edittext"/>

        <!-- PASSWORD -->
        <EditText
            android:id="@+id/textPassword"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:hint="Password"
            android:padding="12dp"
            android:inputType="textPassword"
            android:textColor="#000000"
            android:textColorHint="#000000"
            android:layout_marginBottom="24dp"
            android:background="@drawable/rounded_edittext"/>/>

        <!-- BOTTONE ENTRA -->
        <Button
            android:id="@+id/sendButton"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="Entra"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#1A73E8"
            android:textColor="#FFFFFF"
            android:elevation="4dp"
            android:layout_marginBottom="20dp" />

        <!-- LINK REGISTRAZIONE -->
        <TextView
            android:id="@+id/registerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Non hai un account?"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginBottom="0dp" />

        <TextView
            android:id="@+id/linkRegisterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registrati qui"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#00BCD4"
            android:layout_marginBottom="40dp" />

        <!-- BOTTONE INVIA EMAIL VERIFICA (se vuoi tenerlo) -->
        <Button
            android:id="@+id/verifybutton"
            android:layout_width="280dp"
            android:layout_height="55dp"
            android:text="Invia Email di Verifica"
            android:textSize="16sp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#1A73E8"
            android:elevation="4dp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>

</ScrollView>